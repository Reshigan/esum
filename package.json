{
  "name": "esum-energy-trading-platform",
  "version": "1.0.0",
  "private": true,
  "description": "ESUM Energy Trading Platform - Open Market Energy Trading Platform for South Africa",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "deploy": "turbo run deploy",
    "seed": "tsx scripts/seed-database.ts",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "@playwright/test": "^1.41.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "author": "NXT Business Solutions",
  "license": "CONFIDENTIAL"
}
